# ---- CORS ----
# Comma-separated origins allowed to call this API.
ALLOWED_ORIGINS=http://localhost:4321

# ---- SMTP (optional) ----
# Leave blank to log submissions to the console instead of emailing them.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@blocly.com
CONTACT_RECIPIENT=hello@blocly.com

ENVIRONMENT=development
