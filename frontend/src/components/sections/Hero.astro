---
import Button from "@/components/ui/Button.astro";
import Eyebrow from "@/components/ui/Eyebrow.astro";
import { content } from "@/data/content";

const { eyebrow, headlineTop, headlineAccent, body, primaryCta, secondaryCta, marquee } =
  content.hero;

// Emphasise the brand name within the body copy.
const bodyHtml = body.replace(
  "Blocly",
  '<strong class="font-semibold text-fg">Blocly</strong>',
);

// Duplicate the marquee list so the loop is seamless.
const ticker = [...marquee, ...marquee];
---

<section class="relative overflow-hidden">
  <!-- Ambient grid + glow -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.4]"
    style="background-image:linear-gradient(to right,#ffffff08 1px,transparent 1px),linear-gradient(to bottom,#ffffff08 1px,transparent 1px);background-size:64px 64px;"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute right-[-10%] top-1/3 h-[480px] w-[480px] rounded-full bg-lime/10 blur-[140px]"
    aria-hidden="true"
  >
  </div>

  <div class="container-bl relative pb-10 pt-20 md:pt-28">
    <Eyebrow withRule>{eyebrow}</Eyebrow>

    <h1 class="heading text-hero mt-8 max-w-[14ch]">
      <span class="block">{headlineTop}</span>
      <span class="block text-lime">{headlineAccent}</span>
    </h1>

    <p
      class="mt-9 max-w-xl text-base leading-relaxed text-fg-muted md:text-lg"
      set:html={bodyHtml}
    />

    <div class="mt-10 flex flex-wrap gap-4">
      <Button href={primaryCta.href}>{primaryCta.label}</Button>
      <Button href={secondaryCta.href} variant="secondary">
        {secondaryCta.label}
      </Button>
    </div>
  </div>

  <!-- Capability marquee -->
  <div class="relative mt-12 overflow-hidden border-y border-line py-4">
    <div class="flex w-max animate-marquee gap-10 whitespace-nowrap">
      {
        ticker.map((item) => (
          <span class="flex items-center gap-10 font-mono text-xs uppercase tracking-[0.18em] text-fg-subtle">
            {item}
            <span class="text-lime/50">/</span>
          </span>
        ))
      }
    </div>
  </div>
</section>