---
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Eyebrow from "@/components/ui/Eyebrow.astro";
import { content } from "@/data/content";

const { eyebrow, headlineTop, headlineBottom, steps } = content.process;
---

<SectionContainer id="process" bordered>
  <Eyebrow>{eyebrow}</Eyebrow>
  <h2 class="heading text-display mt-5">
    <span class="block">{headlineTop}</span>
    <span class="block">{headlineBottom}</span>
  </h2>

  <ol class="mt-16 grid gap-12 md:grid-cols-4 md:gap-8">
    {
      steps.map((step) => (
        <li class="relative">
          {/* Connector line (desktop) */}
          <span
            class="absolute left-0 right-0 top-[6px] hidden h-px bg-line md:block"
            aria-hidden="true"
          />
          {/* Node */}
          <span
            class="relative block h-3.5 w-3.5 rounded-full border border-lime bg-ink"
            aria-hidden="true"
          />

          <p class="mt-7 font-mono text-[0.7rem] uppercase tracking-[0.22em] text-lime/70">
            Step {step.id}
          </p>
          <h3 class="heading mt-3 text-2xl">{step.title}</h3>
          <p class="mt-4 text-sm leading-relaxed text-fg-subtle">
            {step.description}
          </p>
        </li>
      ))
    }
  </ol>
</SectionContainer>