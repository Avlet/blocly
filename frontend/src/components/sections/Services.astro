---
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Eyebrow from "@/components/ui/Eyebrow.astro";
import Tag from "@/components/ui/Tag.astro";
import { content } from "@/data/content";

const { eyebrow, headlineTop, headlineBottom, intro, items } = content.services;
---

<SectionContainer id="services" bordered>
  <!-- Header: headline left, intro offset right -->
  <div class="grid gap-8 lg:grid-cols-12 lg:items-end">
    <div class="lg:col-span-7">
      <Eyebrow>{eyebrow}</Eyebrow>
      <h2 class="heading text-display mt-5">
        <span class="block">{headlineTop}</span>
        <span class="block">{headlineBottom}</span>
      </h2>
    </div>
    <p class="text-base leading-relaxed text-fg-muted lg:col-span-5 lg:pb-2">
      {intro}
    </p>
  </div>

  <!-- Hairline card grid (auto-fits ~6 across on desktop, reflows down) -->
  <div
    class="mt-16 grid border-l border-t border-line"
    style="grid-template-columns:repeat(auto-fit,minmax(215px,1fr));"
  >
    {
      items.map((service) => (
        <article class="group relative flex flex-col border-b border-r border-line p-6 transition-colors duration-300 hover:bg-surface-2/40">
          <span class="absolute inset-x-0 top-0 h-px scale-x-0 bg-lime transition-transform duration-300 group-hover:scale-x-100" />

          <span class="font-mono text-xs tracking-[0.15em] text-lime">
            {service.id}
          </span>

          <h3 class="heading mt-4 text-lg leading-[1.05]">{service.title}</h3>

          <div class="mt-4 space-y-3">
            {service.paragraphs.map((p) => (
              <p class="text-[0.82rem] leading-relaxed text-fg-subtle">{p}</p>
            ))}
          </div>

          <div class="mt-6 flex flex-wrap gap-2 pt-2">
            {service.tags.map((tag) => (
              <Tag>{tag}</Tag>
            ))}
          </div>
        </article>
      ))
    }
  </div>
</SectionContainer>