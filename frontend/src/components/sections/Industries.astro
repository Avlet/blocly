---
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Eyebrow from "@/components/ui/Eyebrow.astro";
import { content } from "@/data/content";

const { eyebrow, headline, intro, items } = content.industries;
---

<SectionContainer id="industries" bordered>
  <div class="max-w-3xl">
    <Eyebrow>{eyebrow}</Eyebrow>
    <h2 class="heading text-display mt-5 max-w-[16ch]">{headline}</h2>
    <p class="mt-7 text-base leading-relaxed text-fg-muted">{intro}</p>
  </div>

  <!-- Hairline grid: ~9 across on wide desktop, reflows down -->
  <div
    class="mt-16 grid border-l border-t border-line"
    style="grid-template-columns:repeat(auto-fit,minmax(150px,1fr));"
  >
    {
      items.map((industry) => (
        <article class="group flex flex-col border-b border-r border-line p-5 transition-colors duration-300 hover:bg-surface-2/40">
          <span
            class="text-lime/70 transition-colors group-hover:text-lime"
            aria-hidden="true"
          >
            &#9670;
          </span>
          <h3 class="heading mt-6 text-[0.95rem] leading-tight">
            {industry.name}
          </h3>
          <p class="mt-3 text-[0.78rem] leading-relaxed text-fg-subtle">
            {industry.description}
          </p>
        </article>
      ))
    }
  </div>
</SectionContainer>