---
import SectionContainer from "@/components/ui/SectionContainer.astro";
import Eyebrow from "@/components/ui/Eyebrow.astro";
import { content } from "@/data/content";

const { eyebrow, headline, lead, highlights, body, pillars } =
  content.growthChallenge;

// Wrap highlighted words in the accent colour.
let leadHtml = lead;
for (const word of highlights) {
  leadHtml = leadHtml.replace(word, `<span class="text-lime">${word}</span>`);
}
---

<SectionContainer bordered>
  <Eyebrow>{eyebrow}</Eyebrow>
  <h2 class="heading text-display mt-5 max-w-[12ch]">{headline}</h2>

  <div class="mt-14 grid gap-14 lg:grid-cols-2 lg:gap-20">
    <!-- Narrative -->
    <div class="max-w-2xl">
      <p
        class="text-lg leading-relaxed text-fg md:text-xl md:leading-relaxed"
        set:html={leadHtml}
      />
      <p class="mt-7 text-base leading-relaxed text-fg-muted">{body}</p>
    </div>

    <!-- Pillars -->
    <div class="grid gap-px bg-line sm:grid-cols-2 lg:grid-cols-1 lg:bg-transparent lg:gap-0">
      {
        pillars.map((pillar) => (
          <div class="bg-ink py-6 lg:border-l lg:border-line lg:pl-6">
            <h3 class="font-mono text-xs uppercase tracking-[0.18em] text-fg">
              {pillar.title}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-fg-subtle">
              {pillar.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</SectionContainer>