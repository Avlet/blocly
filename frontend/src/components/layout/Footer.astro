---
import { content } from "@/data/content";

const { name, tagline, email, socials, nav } = content.site;
const year = new Date().getFullYear();

// Build the Services column from the real service list.
const serviceLinks = content.services.items.map((s) => ({
  label: s.title,
  href: "#services",
}));

const columns = [
  { title: "Services", links: serviceLinks },
  { title: "Company", links: nav },
  {
    title: "Connect",
    links: [
      ...socials,
      { label: email, href: `mailto:${email}` },
    ],
  },
];
---

<footer class="border-t border-line bg-ink">
  <div class="container-bl py-16 md:py-20">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-12 md:gap-8">
      <div class="md:col-span-5">
        <a
          href="/"
          class="font-display text-3xl uppercase leading-none tracking-tight text-fg"
          aria-label={`${name} — home`}
        >
          {name}<span class="text-lime">.</span>
        </a>
        <p class="mt-5 max-w-sm text-sm leading-relaxed text-fg-subtle">
          A full-service growth marketing, PR, and communications agency for
          crypto, blockchain, fintech, and global technology brands. We convert
          your story into market leadership.
        </p>
        <p class="eyebrow mt-8">{tagline}</p>
      </div>

      <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 md:col-span-7">
        {
          columns.map((col) => (
            <nav aria-label={col.title}>
              <h2 class="font-mono text-xs uppercase tracking-[0.18em] text-fg">
                {col.title}
              </h2>
              <ul class="mt-5 space-y-3">
                {col.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="text-sm text-fg-subtle transition-colors duration-200 hover:text-fg"
                    >
                      {link.label}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          ))
        }
      </div>
    </div>

    <div class="mt-14 flex flex-col gap-4 border-t border-line pt-8 sm:flex-row sm:items-center sm:justify-between">
      <p class="font-mono text-xs tracking-wide text-fg-subtle">
        &copy; {year} {name}. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="#" class="font-mono text-xs uppercase tracking-[0.15em] text-fg-subtle transition-colors hover:text-fg">Privacy</a>
        <a href="#" class="font-mono text-xs uppercase tracking-[0.15em] text-fg-subtle transition-colors hover:text-fg">Terms</a>
      </div>
    </div>
  </div>
</footer>