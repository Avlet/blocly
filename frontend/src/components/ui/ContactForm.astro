---
import { content } from "@/data/content";
const { email } = content.site;

const submitClass =
  "inline-flex items-center justify-center rounded-[2px] bg-lime px-7 py-3.5 font-mono text-xs font-bold uppercase tracking-[0.15em] text-ink transition-colors duration-200 hover:bg-lime-dim disabled:cursor-not-allowed disabled:opacity-60";
---

<div id="contact-form" class="mx-auto mt-16 max-w-3xl scroll-mt-24 text-left">
  <div class="border border-line bg-surface/40 p-8 md:p-10">
    <h3 class="heading text-headline">Start a conversation.</h3>
    <p class="mt-3 text-sm leading-relaxed text-fg-muted">
      Tell us about your project and we'll respond within one business day — or
      email us directly at
      <a href={`mailto:${email}`} class="text-lime hover:underline">{email}</a>.
    </p>

    <form id="blocly-contact" class="mt-8 space-y-5" novalidate>
      <!-- Honeypot: hidden from users, catches bots -->
      <div class="absolute left-[-9999px] top-auto h-px w-px overflow-hidden" aria-hidden="true">
        <label for="cf-website">Website</label>
        <input id="cf-website" name="website" type="text" tabindex="-1" autocomplete="off" />
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="cf-name" class="form-label">Name</label>
          <input id="cf-name" name="name" type="text" required minlength="2"
            placeholder="Your name" class="form-input" />
        </div>
        <div>
          <label for="cf-email" class="form-label">Email</label>
          <input id="cf-email" name="email" type="email" required
            placeholder="you@company.com" class="form-input" />
        </div>
      </div>

      <div>
        <label for="cf-company" class="form-label">
          Company <span class="text-fg-subtle">(optional)</span>
        </label>
        <input id="cf-company" name="company" type="text"
          placeholder="Company or project" class="form-input" />
      </div>

      <div>
        <label for="cf-message" class="form-label">How can we help?</label>
        <textarea id="cf-message" name="message" rows="5" required minlength="10"
          placeholder="Tell us where you want to go." class="form-input resize-y"></textarea>
      </div>

      <div class="flex flex-col gap-4 pt-1 sm:flex-row sm:items-center sm:justify-between">
        <button id="cf-submit" type="submit" class={submitClass}>Send Message</button>
        <p id="cf-status" role="status" aria-live="polite" class="text-sm text-fg-subtle"></p>
      </div>
    </form>
  </div>
</div>

<script>
  import { submitContact } from "@/lib/api";

  const form = document.getElementById("blocly-contact") as HTMLFormElement | null;
  const statusEl = document.getElementById("cf-status");
  const submitBtn = document.getElementById("cf-submit") as HTMLButtonElement | null;

  function setStatus(message: string, kind: "idle" | "success" | "error") {
    if (!statusEl) return;
    statusEl.textContent = message;
    const tone =
      kind === "success"
        ? "text-lime"
        : kind === "error"
          ? "text-red-400"
          : "text-fg-subtle";
    statusEl.className = `text-sm ${tone}`;
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const data = new FormData(form);
    const payload = {
      name: String(data.get("name") ?? "").trim(),
      email: String(data.get("email") ?? "").trim(),
      company: String(data.get("company") ?? "").trim() || undefined,
      message: String(data.get("message") ?? "").trim(),
      website: String(data.get("website") ?? ""),
    };

    const originalLabel = submitBtn?.textContent ?? "Send Message";
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.textContent = "Sending…";
    }
    setStatus("", "idle");

    try {
      const result = await submitContact(payload);
      setStatus(result.message, "success");
      form.reset();
    } catch (error) {
      setStatus(
        error instanceof Error ? error.message : "Something went wrong.",
        "error",
      );
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = originalLabel;
      }
    }
  });
</script>